# === Erfolgs-Dashboard – Konfiguration ===
# Kopiere diese Datei zu ".env" und trage deine Keys ein.
# Die ".env" wird NICHT eingecheckt (siehe .gitignore).

# --- Phase 1: Vanity Metrics ---
# YouTube Data API v3 (Google Cloud Console, kostenlos)
YOUTUBE_API_KEY=
# Kanal: entweder feste Channel-ID (UC...) ODER Handle (@MatthiasMorr)
YOUTUBE_CHANNEL_ID=
YOUTUBE_CHANNEL_HANDLE=

# KIT (ConvertKit) v4 API-Key
KIT_API_KEY=

# --- Phase 1: Einnahmen ---
# Digistore24 Vendor-API-Key (Einstellungen → API)
DIGISTORE_API_KEY=

# Awin Publisher-API (OAuth-Token + deine Publisher-ID)
AWIN_API_TOKEN=
AWIN_PUBLISHER_ID=

# --- Phase 2: KI-Auswertung (später) ---
ANTHROPIC_API_KEY=

# YouTube-Werbeeinnahmen (YouTube Analytics API, OAuth)
# Einmalig: ./venv/bin/python auth_youtube.py  -> setzt YT_OAUTH_REFRESH_TOKEN
YT_OAUTH_CLIENT_ID=
YT_OAUTH_CLIENT_SECRET=
YT_OAUTH_REFRESH_TOKEN=

# Lexware Office Public API (Einstellungen -> Öffentliche API -> Schlüssel erzeugen)
LEXWARE_API_KEY=

# --- Festbuchungen-Excel automatisch aus Google Drive ziehen (OAuth, readonly) ---
# Einmalig: ./venv/bin/python auth_drive.py  -> setzt DRIVE_OAUTH_REFRESH_TOKEN
# Nutzt standardmäßig den YouTube-OAuth-Client (YT_OAUTH_*); optional eigener Client:
DRIVE_OAUTH_CLIENT_ID=
DRIVE_OAUTH_CLIENT_SECRET=
DRIVE_OAUTH_REFRESH_TOKEN=
# Datei wird über KREUZFAHRTSTUDIO_FILE_ID geladen (siehe oben).

# --- Social-Reichweite (Accountwachstum: Instagram · Facebook · TikTok) ---
# Instagram + Facebook: EIN langlebiges Page-Access-Token deckt beide ab.
#   Voraussetzung: IG ist ein Business-/Creator-Account, mit der FB-Seite verknüpft.
#   Token holen: developers.facebook.com -> App (Typ "Business") -> Graph API Explorer
#   -> Page-Token mit Scopes pages_read_engagement, pages_show_list,
#      instagram_basic, business_management -> dann zu langlebigem Token tauschen.
META_ACCESS_TOKEN=
# Optional: Seiten-ID festnageln (sonst wird die erste Seite aus /me/accounts genommen)
META_PAGE_ID=
# Optional: Graph-API-Version (Default v21.0)
META_API_VERSION=

# TikTok Display API (developers.tiktok.com -> App -> Scope user.info.stats -> OAuth)
TIKTOK_ACCESS_TOKEN=
